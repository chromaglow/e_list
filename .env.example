# .env.example — FriendSwap environment variable contract
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it contains real secrets.
#
# Generating values:
#   INVITE_TOKEN:        node scripts/gen-invite-token.js
#   SESSION_SECRET:      node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#                        OR: openssl rand -base64 32
#   TURSO_DATABASE_URL:  Turso dashboard → app.turso.tech → Database → Connect
#   TURSO_AUTH_TOKEN:    Turso dashboard → app.turso.tech → Database → Tokens → Create token
#   ADMIN_PASSWORD_HASH: node scripts/gen-hash.js <your-admin-password>  (Plan 03 creates this script)
#   BLOB_READ_WRITE_TOKEN: Vercel dashboard → Storage → Blob store → Tokens  (Plan 04)
#
# Security note (T-01-03): The invite token appears in browser history and server
# access logs because it is a URL path segment. Token rotation UI is in Phase 3
# (ADMN-04). Keep the .env.local file secret and rotate the token if compromised.

# Access gate — 64 lowercase hex chars from 32 cryptographically random bytes
INVITE_TOKEN=<64-hex-chars-from-node-scripts/gen-invite-token.js>

# JWT signing key — base64-encoded random bytes (>= 32 bytes decoded)
SESSION_SECRET=<base64-32-bytes-from-openssl-rand-base64-32>

# Turso database connection (Plan 02+)
TURSO_DATABASE_URL=<libsql://your-db-name.turso.io>
TURSO_AUTH_TOKEN=<turso-auth-token-from-dashboard>

# Admin credentials (Plan 03+)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<bcrypt-hash-cost-12-from-node-scripts/gen-hash.js>

# Vercel Blob storage (Plan 04+)
BLOB_READ_WRITE_TOKEN=<vercel-blob-read-write-token>
